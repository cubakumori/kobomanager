<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /api/
  # Todo el tráfico de la API pasa por el front controller index.php
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ index.php [QSA,L]
</IfModule>

# Nunca servir config.php ni archivos sensibles directamente
<FilesMatch "^(config|config\.example)\.php$">
  Require all denied
</FilesMatch>
