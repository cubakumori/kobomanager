# KoboManager — .htaccess de la raíz pública (Apache).
# Vite lo copia tal cual a dist/, así que llega al servidor junto al build.
# En nginx este archivo se ignora: replica las reglas según DEPLOY.md §6.

<IfModule mod_rewrite.c>
  RewriteEngine On
  # /api va aparte (tiene su propio .htaccess con el front controller)
  RewriteRule ^api/ - [L]
  # Si el archivo no existe, servir la SPA (rutas internas del router)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# PWA: el service worker debe revalidarse pronto para que las actualizaciones
# lleguen; assets/ va con hash de contenido y puede cachearse agresivamente.
<IfModule mod_headers.c>
  <Files "sw.js">
    Header set Cache-Control "no-cache"
  </Files>

  # Cabeceras de seguridad del documento SPA (defensa en profundidad; el API
  # manda las suyas aparte en api/v1/index.php).
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "no-referrer"
  Header set X-Frame-Options "DENY"

  # Content-Security-Policy SOLO sobre respuestas text/html (la propia SPA): no
  # toca /assets, ni las respuestas JSON del API, ni la CSP propia del proxy
  # público de adjuntos (`default-src 'none'; sandbox`), que es otro content-type.
  #
  # script-src lleva el HASH del <script> inline de tema de index.html (evita
  # 'unsafe-inline'). Si EDITAS ese script, recalcula el hash o el modo oscuro
  # romperá la CSP:
  #   php -r '$h=file_get_contents("index.html");preg_match("#<script>(.*?)</script>#s",$h,$m);echo "sha256-".base64_encode(hash("sha256",$m[1],true));'
  # style-src 'unsafe-inline' es necesario para los estilos en línea de Vue/Leaflet.
  # img-src añade los tiles de OpenStreetMap del mapa (Leaflet).
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-GyOuvgU4KjskfU9dxnY0uNhKMq9b4ZTdIG6/cUjqa4c='; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.tile.openstreetmap.org; font-src 'self'; connect-src 'self'; manifest-src 'self'; worker-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'" "expr=%{CONTENT_TYPE} =~ m#text/html#"
</IfModule>
